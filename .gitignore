# PYTHON
# ════════════════════════════════════════════════════════════

__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
.env/
ENV/

# uv
.uv/

# pytest
.pytest_cache/
.cache/

# Coverage
.coverage
.coverage.*
htmlcov/
coverage.xml

# mutmut
.mutmut-cache

# hypothesis
.hypothesis/

# Distribución / packaging
*.egg-info/
dist/
build/
*.egg

# ════════════════════════════════════════════════════════════
# JAVA / MAVEN
# ════════════════════════════════════════════════════════════

target/
*.class
*.jar
*.war
*.ear
*.nar

# Maven wrapper
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# JaCoCo
jacoco.exec
jacoco/

# Surefire reports
surefire-reports/

