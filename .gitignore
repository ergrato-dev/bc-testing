# ============================================================
# BOOTCAMP DE TESTING — .gitignore
# Cubre: JavaScript (Jest), Python (pytest), Java (JUnit 5)
# ============================================================

# ── SOLUCIONES DE PROYECTOS (no publicar — anticopia) ────────
# Las soluciones de prácticas SÍ se publican (son tutoriales guiados).
# Solo se excluyen las soluciones de los proyectos semanales.
**/3-proyecto/solution/

# ════════════════════════════════════════════════════════════
# JAVASCRIPT / NODE.JS
# ════════════════════════════════════════════════════════════

node_modules/
dist/
build/
.cache/

# Coverage
coverage/
.nyc_output/

# Jest
junit.xml

# pnpm
.pnpm-store/
.pnpm-debug.log

# yarn
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

